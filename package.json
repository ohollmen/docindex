{
  "name": "docindex",
  "version": "0.0.5",
  "description": "Create Lightweight MD Document Listing Web Pages",
  "author": {
    "name": "Olli Hollmen",
    "email": "olli.hollmen@gmail.com"
  },
  "main": "docindex.js",
  "browser": "docindex.js",
  "dependencies": {
    "bootstrap": "~3.3.7",
    "jquery": "~3.7.1",
    "showdown": "~2.1.0"
  },
  "optionalDependencies": {
    "async": "3.2.0",
    "body-parser": "1.19.0",
    "express": "4.17.1",
    "express-session": "1.17.1",
    "jquery-ui": "~1.12.1",
    "md5-file": "^5.0.0"
  },
  "devDependencies": {
    "jsdoc": "3.6.3"
  },
  "scripts": {
    "jsdoc": "jsdoc *.js -R README.md -c jsdoc.conf.json",
    "copyscratch": "export DI_PATH=/tmp/docindex_`date '+%s'`; mkdir $DI_PATH; rsync -av --exclude .git ./ $DI_PATH; echo \"Copied to $DI_PATH\""
  },
  "keywords": [
    "doc",
    "documentation",
    "technical documentation",
    "markdown",
    "document website"
  ],
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/ohollmen/docindex.git"
  },
  "files": [
    "package.json",
    "docindex.js",
    "docindex.html",
    "docindex.css",
    "docindex.json",
    "docindex_main.js",
    "README.md"
  ]
}
